<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" style="-fx-background-color: -bg-color;" stylesheets="@../styles/light.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.virsa.controller.VictoryController">
    <children>
        <VBox alignment="CENTER" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <!-- Header -->
            <Label text="Lesson Complete!" style="-fx-font-size: 36px; -fx-font-weight: 900; -fx-text-fill: #58CC02;" />
            
            <!-- Stats Container -->
            <HBox alignment="CENTER" spacing="40.0">
                <!-- XP Earned Box -->
                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: -bg-color; -fx-border-color: -border-color; -fx-border-width: 2; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 30;">
                    <Label text="XP Earned" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -text-secondary;" />
                    <Label fx:id="xpLabel" text="+15" style="-fx-font-size: 48px; -fx-font-weight: 900; -fx-text-fill: #1CB0F6;" />
                </VBox>
                
                <!-- Streak Box -->
                <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: -bg-color; -fx-border-color: -border-color; -fx-border-width: 2; -fx-border-radius: 15; -fx-background-radius: 15; -fx-padding: 30;">
                    <Label text="Current Streak" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: -text-secondary;" />
                    <Label fx:id="streakLabel" text="1" style="-fx-font-size: 48px; -fx-font-weight: 900; -fx-text-fill: #FF9600;" />
                </VBox>
            </HBox>

            <Label fx:id="celebrationLabel" text="You're on fire! Streak increased!" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FF9600;" visible="false"/>

            <Button fx:id="btnContinue" text="CONTINUE" onAction="#handleContinue" style="-fx-background-color: #58CC02; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 15 50; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 5, 0, 0, 4);">
                <VBox.margin>
                    <Insets top="40.0" />
                </VBox.margin>
            </Button>
        </VBox>
    </children>
</AnchorPane>
