<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox spacing="25.0" style="-fx-background-color: white; -fx-padding: 30;" stylesheets="@../styles/light.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.virsa.controller.AddLanguageController">

    <Label text="What do you want to learn?" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-font-family: 'Arial Black'; -fx-text-fill: #4B4B4B;" />

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: white;" prefHeight="400.0" prefWidth="350.0">
        <VBox spacing="15.0">
            <padding>
                <Insets bottom="10.0" left="5.0" right="5.0" top="5.0" />
            </padding>

            <!-- Punjabi -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4);">
                <Circle radius="15.0" fill="#FF9600" />
                <Label text="Punjabi" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B4B4B;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#startPunjabi" text="Start" style="-fx-background-color: #58CC02; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 15 8 15; -fx-cursor: hand;" />
            </HBox>

            <!-- Sindhi -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4);">
                <Circle radius="15.0" fill="#1CB0F6" />
                <Label text="Sindhi" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B4B4B;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#startSindhi" text="Start" style="-fx-background-color: #58CC02; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 15 8 15; -fx-cursor: hand;" />
            </HBox>

            <!-- Pashto -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4);">
                <Circle radius="15.0" fill="#CE82FF" />
                <Label text="Pashto" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B4B4B;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#startPashto" text="Start" style="-fx-background-color: #58CC02; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 15 8 15; -fx-cursor: hand;" />
            </HBox>

            <!-- Balochi -->
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 8, 0, 0, 4);">
                <Circle radius="15.0" fill="#FF4B4B" />
                <Label text="Balochi" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #4B4B4B;" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#startBalochi" text="Start" style="-fx-background-color: #58CC02; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 15 8 15; -fx-cursor: hand;" />
            </HBox>

        </VBox>
    </ScrollPane>
</VBox>