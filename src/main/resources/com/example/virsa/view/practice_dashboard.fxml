<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.virsa.controller.PracticeDashboardController">
    <padding>
        <Insets bottom="50.0" top="50.0" left="20.0" right="20.0"/>
    </padding>

    <!-- Header -->
    <VBox alignment="CENTER" spacing="10.0">
        <Label text="❤️" style="-fx-font-size: 72px;" />
        <Label text="PRACTICE MODE" style="-fx-font-size: 32px; -fx-font-weight: 900; -fx-text-fill: #FF4B4B;" />
        <Label text="Review your active course without penalties to earn back your hearts!" style="-fx-font-size: 18px; -fx-text-fill: -text-secondary; -fx-wrap-text: true; -fx-text-alignment: center;" maxWidth="400" />
    </VBox>

    <HBox alignment="CENTER" spacing="20.0">
        <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: -bg-color; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: -border-color; -fx-border-width: 2; -fx-border-radius: 15;">
            <Label text="Reward" style="-fx-text-fill: -text-secondary; -fx-font-weight: bold;"/>
            <Label text="+5 XP" style="-fx-text-fill: #1CB0F6; -fx-font-weight: 900; -fx-font-size: 24px;"/>
        </VBox>
        <VBox alignment="CENTER" spacing="5.0" style="-fx-background-color: -bg-color; -fx-padding: 20; -fx-background-radius: 15; -fx-border-color: -border-color; -fx-border-width: 2; -fx-border-radius: 15;">
            <Label text="Reward" style="-fx-text-fill: -text-secondary; -fx-font-weight: bold;"/>
            <Label text="+1 Heart" style="-fx-text-fill: #FF4B4B; -fx-font-weight: 900; -fx-font-size: 24px;"/>
        </VBox>
    </HBox>

    <Button onAction="#handleStartPractice" text="START PRACTICE" style="-fx-background-color: #FF4B4B; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-padding: 15 50; -fx-background-radius: 15; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.15), 5, 0, 0, 4);" />
</VBox>
