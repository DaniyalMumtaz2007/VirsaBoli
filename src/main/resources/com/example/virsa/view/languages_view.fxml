<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.virsa.controller.LanguagesController">
    <VBox spacing="35.0">
        <padding>
            <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
        </padding>

        <Label text="My Languages" style="-fx-font-size: 26px; -fx-font-weight: 900; -fx-font-family: 'Arial Black'; -fx-text-fill: -text-color;" />

        <FlowPane fx:id="languagesFlowPane" hgap="25.0" vgap="25.0">
            <!-- The Clickable Add Button Tile -->
            <VBox fx:id="addCourseTile" alignment="CENTER" onMouseClicked="#handleAddLanguageClick" spacing="10.0" prefHeight="160.0" prefWidth="140.0" style="-fx-background-color: transparent; -fx-border-color: #AFBFC9; -fx-border-radius: 15; -fx-border-width: 3; -fx-border-style: dashed; -fx-cursor: hand;">
                <Label text="+" style="-fx-font-size: 48px; -fx-text-fill: #AFBFC9; -fx-font-weight: bold;" />
                <Label text="ADD COURSE" style="-fx-font-weight: bold; -fx-text-fill: #AFBFC9;" />
            </VBox>
        </FlowPane>
    </VBox>
</ScrollPane>