<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="mainContainer" prefHeight="700.0" prefWidth="1000.0" stylesheets="@../styles/light.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.virsa.controller.MainDashboardController">
    <!-- NEW TOP BAR -->
    <top>
        <HBox alignment="CENTER_RIGHT" spacing="30.0" style="-fx-background-color: -bg-color; -fx-padding: 15 40 15 40; -fx-border-color: -border-color; -fx-border-width: 0 0 2 0;">

            <!-- Flag/Language Indicator -->
            <HBox alignment="CENTER" spacing="10.0">
                <Label fx:id="topLangLabel" text="No Course" style="-fx-font-weight: bold; -fx-text-fill: -text-secondary;" />
            </HBox>

            <Region HBox.hgrow="ALWAYS" /> <!-- Pushes stats to the right -->

            <!-- Streak -->
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="🔥" style="-fx-font-size: 18px;" />
                <Label fx:id="topStreakLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #FF9600; -fx-font-size: 16px;" />
            </HBox>

            <!-- XP / Gems -->
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="💎" style="-fx-font-size: 18px;" />
                <Label fx:id="topXpLabel" text="0" style="-fx-font-weight: bold; -fx-text-fill: #1CB0F6; -fx-font-size: 16px;" />
            </HBox>

            <!-- Hearts -->
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="❤️" style="-fx-font-size: 18px;" />
                <Label fx:id="topHeartsLabel" text="5" style="-fx-font-weight: bold; -fx-text-fill: #FF4B4B; -fx-font-size: 16px;" />
            </HBox>
        </HBox>
    </top>
    <left>
        <VBox fx:id="sidebar" prefWidth="250.0" spacing="15.0" styleClass="sidebar">
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
            </padding>
            <children>
                <ImageView fitHeight="60.0" fitWidth="180.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../Images/VirsaLogo.png" />
                    </image>
                    <VBox.margin>
                        <Insets bottom="30.0" />
                    </VBox.margin>
                </ImageView>
                <Button fx:id="btnLessons" maxWidth="Infinity" onAction="#handleNavLessons" styleClass="nav-button" text="LESSONS" />
                <Button fx:id="btnLanguages" maxWidth="Infinity" onAction="#handleNavLanguages" styleClass="nav-button" text="LANGUAGES" />
                <Button fx:id="btnProfile" maxWidth="Infinity" onAction="#handleNavProfile" styleClass="nav-button" text="PROFILE" />
                <Button fx:id="btnPractice" maxWidth="Infinity" onAction="#handleNavPractice" styleClass="nav-button" text="PRACTICE" />
                <Region VBox.vgrow="ALWAYS" />
                <Button fx:id="btnSettings" maxWidth="Infinity" onAction="#handleNavSettings" styleClass="nav-button" text="SETTINGS" />
            </children>
        </VBox>
    </left>
    <center>
        <AnchorPane fx:id="contentArea" styleClass="content-area">
            <!-- Dynamic content will be loaded here -->
        </AnchorPane>
    </center>
</BorderPane>
