<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane style="-fx-background-color: -bg-color;" stylesheets="@../styles/light.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.virsa.controller.ActiveLessonController">

    <!-- TOP BAR: Progress and Hearts -->
    <top>
        <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 20 40 20 40;">
            <Button onAction="#handleClose" text="✕" style="-fx-background-color: transparent; -fx-font-size: 24px; -fx-text-fill: -text-secondary; -fx-cursor: hand; -fx-font-weight: bold;" />
            <ProgressBar fx:id="lessonProgressBar" progress="0.0" HBox.hgrow="ALWAYS" maxWidth="Infinity" prefHeight="15.0" style="-fx-accent: #58CC02; -fx-control-inner-background: #E5E5E5; -fx-background-radius: 10;" />
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="❤️" style="-fx-font-size: 24px;" />
                <Label fx:id="heartsLabel" text="5" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #FF4B4B;" />
            </HBox>
        </HBox>
    </top>

    <!-- CENTER: The Question and Options -->
    <center>
        <VBox alignment="CENTER" maxWidth="600.0" spacing="40.0" style="-fx-padding: 20;">
            <Label fx:id="questionTypeLabel" text="Translate this word" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-font-family: 'Arial Black'; -fx-text-fill: -text-primary;" />

            <!-- Dynamic Multimedia Container -->
            <HBox alignment="CENTER" spacing="15.0">
                <!-- This button is hidden by default! -->
                <Button fx:id="audioPlayButton" onAction="#handlePlayAudio" text="🔊" visible="false" managed="false" style="-fx-background-color: #1CB0F6; -fx-text-fill: white; -fx-font-size: 24px; -fx-background-radius: 50; -fx-min-width: 60; -fx-min-height: 60; -fx-cursor: hand; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 5, 0, 0, 4);" />

                <Label fx:id="questionPromptLabel" text="Seb" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: -primary-blue;" />
            </HBox>
            <!-- Options Grid (Dynamically filled by Java) -->
            <FlowPane fx:id="optionsContainer" alignment="CENTER" hgap="20.0" vgap="20.0">
                <!-- Buttons will be injected here -->
            </FlowPane>
            
            <!-- Paragraph Input (Hidden by default) -->
            <TextArea fx:id="paragraphInputField" promptText="Type your answer here..." wrapText="true" prefHeight="100" visible="false" managed="false" style="-fx-font-size: 16px; -fx-padding: 10; -fx-background-radius: 10; -fx-border-color: -border-color; -fx-border-width: 2; -fx-border-radius: 10;" />
        </VBox>
    </center>

    <!-- BOTTOM: Feedback Banner and Check Button -->
    <bottom>
        <VBox fx:id="bottomBanner" alignment="CENTER" spacing="15.0" style="-fx-padding: 30 40 30 40; -fx-border-color: -border-color; -fx-border-width: 2 0 0 0;">
            <HBox alignment="CENTER_LEFT" spacing="20.0">
                <VBox fx:id="feedbackTextContainer" visible="false" managed="false" spacing="5.0" HBox.hgrow="ALWAYS">
                    <Label fx:id="feedbackTitle" text="Correct!" style="-fx-font-size: 24px; -fx-font-weight: 900; -fx-font-family: 'Arial Black';" />
                    <Label fx:id="feedbackSubtitle" text="Good job!" style="-fx-font-size: 16px; -fx-font-weight: bold;" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="mainActionButton" onAction="#handleMainAction" text="CHECK" minWidth="150.0" style="-fx-background-color: #E5E5E5; -fx-text-fill: #AFBFC9; -fx-font-size: 18px; -fx-font-weight: bold; -fx-padding: 15 30 15 30; -fx-background-radius: 15; -fx-cursor: hand;" />
            </HBox>
        </VBox>
    </bottom>
</BorderPane>